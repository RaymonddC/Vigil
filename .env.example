# -----------------------------------------------------------------------------
# Required by docker-compose.yml — compose will refuse to start without these.
# -----------------------------------------------------------------------------

# Shared secret for the X-API-Key middleware on mcp / a2a / api (SEC-05).
# Any non-empty string for local dev. Rotate in production.
VIGIL_API_KEY=local-dev-key-change-me

# Public hostname Caddy issues a Let's Encrypt cert for, and the base of
# A2A_PUBLIC_URL + CORS_ORIGINS when those aren't set explicitly.
# Leave blank for local HTTP on :80 (Caddy's default site address).
SITE_DOMAIN=

# Optional overrides — only set if you want something other than the
# SITE_DOMAIN-derived defaults in docker-compose.yml.
# CORS_ORIGINS=https://your-domain.example
# A2A_PUBLIC_URL=https://your-domain.example/a2a    # note /a2a suffix

# -----------------------------------------------------------------------------
# LLM provider — one of: ollama, groq, claude, gemini, stub
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama

# Ollama (default dev)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Groq (integration)
GROQ_API_KEY=

# Anthropic / Claude (video recording)
ANTHROPIC_API_KEY=

# Google Gemini — same provider Prompt Opinion uses by default. Get a free
# key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# -----------------------------------------------------------------------------
# FHIR — overridden by SHARP headers in production
# -----------------------------------------------------------------------------
FHIR_BASE_URL=http://localhost:8080/fhir

# Demo-mode synthetic FHIR fallback. When ON and the live FHIR server
# rejects our SHARP-authenticated read (e.g. PO's workspace doesn't inject
# a scoped bearer token), MCP tools fall back to PT-007's bundled FHIR
# data so screens return real clinical reasoning. Every fallback response
# is tagged data_source=synthetic_demo for honest disclosure.
# Flip to true to enable the synthetic PT-007 fallback for demo recordings;
# docker-compose.yml propagates this into the mcp + a2a containers.
VIGIL_SYNTHETIC_FALLBACK=false

# Agent
POLL_INTERVAL_SEC=900

# Backend (fixture fallback for KS-2)
FHIR_BACKEND=hapi
