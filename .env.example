# LLM Provider — one of: ollama, groq, claude, stub
LLM_PROVIDER=ollama

# Ollama (default dev)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Groq (integration)
GROQ_API_KEY=

# Anthropic / Claude (video recording)
ANTHROPIC_API_KEY=

# FHIR (overridden by SHARP headers in production)
FHIR_BASE_URL=http://localhost:8080/fhir

# Agent
POLL_INTERVAL_SEC=900

# Backend (fixture fallback for KS-2)
FHIR_BACKEND=hapi
